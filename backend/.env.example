# 실행 환경
APP_ENV=development

# 거래 모드 — paper(기본, 모의투자) | live(실전). live는 명시적 전환만.
TRADING_MODE=paper

# KIS 인증 (시크릿 — 절대 git 커밋 금지)
# 모의/실전은 각자 별도 앱키·시크릿·계좌를 쓴다(폴백 없음).
# 사용할 모드의 세트만 채우면 된다(예: 모의만 쓰면 KIS_PAPER_* 만).
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
KIS_LIVE_ACCOUNT_NO=
# 계좌상품코드(2자리) — 모의/실전 공용
KIS_ACCOUNT_PRODUCT=01

# 기동 시 KIS 접근토큰 프리워밍(첫 시세/잔고 호출 지연 감소). 기본 true.
KIS_TOKEN_PREWARM=true

# KIS 호출 간 최소 간격(초) — 초당 거래건수 초과(EGW00201) 사전 억제.
# 비우면 모드별 기본값(paper≈0.45, live≈0.06). 모의에서 추천 누락이 잦으면 0.5로.
KIS_MIN_CALL_INTERVAL_SEC=

# 서버 호스트/포트는 저장소 루트 .env(BACKEND_HOST/BACKEND_PORT)로 이전됨 — 루트 .env.example 참고.

# 안전 가드
DAILY_MAX_ORDERS=100
DAILY_MAX_AMOUNT=1000000
DAILY_MAX_LOSS=0           # 하루 손실 한도(원, 0=비활성). 당일 실현손익 -이값 이하면 신규 매수 중단
# 시간 필터(전역, 분; 0=비활성)
ENTRY_BLOCK_AFTER_OPEN_MIN=0   # 장 시작(09:00) 후 N분 신규 진입 금지
ENTRY_BLOCK_BEFORE_CLOSE_MIN=0 # 장 마감(15:30) 전 N분 신규 진입 금지

# 데이터베이스
DATABASE_PATH=./data/sstock.db

# 분야별 추천 시세 데이터 소스 — kis(기본, KIS OpenAPI) | krx(KRX 일별매매 스냅샷)
RECOMMEND_DATA_SOURCE=kis

# KRX 데이터 OpenAPI 키 (시크릿 — 절대 git 커밋 금지)
KRX_API_KEY=
