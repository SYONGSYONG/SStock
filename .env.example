# ── SStock 네트워크/포트 (단일 출처) ───────────────────────────
# 기동 스크립트(start*.bat, scripts/*.ps1)와 frontend/vite.config.ts가
# 모두 이 파일을 읽는다. 포트를 바꾸려면 여기 한 곳만 수정하면 된다.
# 이 파일(.env.example)은 템플릿이며, 실제 값은 .env에 둔다(.env는 git 제외).

# 백엔드(FastAPI/uvicorn). 보통 루프백 유지 — 외부 노출 불필요(프론트가 프록시로 전달).
BACKEND_HOST=127.0.0.1
# 형제 프로젝트 TossStock이 8000을 쓰므로 SStock 백엔드는 8010으로 분리(충돌 방지).
BACKEND_PORT=8010

# 프론트(vite dev 서버 = 브라우저 접속 대상).
# FRONTEND_HOST=true  → 0.0.0.0 바인딩(같은 네트워크 다른 PC에서 접속 허용)
# FRONTEND_HOST=127.0.0.1 → 이 PC에서만 접속(보안 기본값)
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8001
