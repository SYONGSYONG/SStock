# 실행 환경
APP_ENV=development

# 거래 모드 — paper(기본, 모의투자) | live(실전). live는 명시적 전환만.
TRADING_MODE=paper

# KIS 인증 (시크릿 — 절대 git 커밋 금지)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT=01

# 기동 시 KIS 접근토큰 프리워밍(첫 시세/잔고 호출 지연 감소). 기본 true.
KIS_TOKEN_PREWARM=true

# KIS 호출 간 최소 간격(초) — 초당 거래건수 초과(EGW00201) 사전 억제.
# 비우면 모드별 기본값(paper≈0.45, live≈0.06). 모의에서 추천 누락이 잦으면 0.5로.
KIS_MIN_CALL_INTERVAL_SEC=

# 서버
HOST=127.0.0.1
PORT=8000

# 안전 가드
DAILY_MAX_ORDERS=20
DAILY_MAX_AMOUNT=1000000

# 데이터베이스
DATABASE_PATH=./data/sstock.db
